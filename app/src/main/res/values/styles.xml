<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">
        <!-- Стиль для NavigationView -->
        <style name="CustomNavigationView" parent="Widget.Design.NavigationView">
            <!-- Змінюємо фонове зображення для кожного елементу меню -->
            <item name="android:itemBackground">@drawable/menu_item_background</item>
            <!-- Встановлюємо стиль для тексту пунктів меню -->
            <item name="android:background">@color/background_color</item>
            <item name="android:textAppearance">@style/CustomTextAppearance</item>
        </style>

    <style name="EditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/edit_text_underline_light</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textColorHint">@android:color/darker_gray</item>
    </style>

        <!-- Стиль для тексту пунктів меню -->
        <style name="CustomTextAppearance">
            <item name="android:textSize">18sp</item> <!-- Збільшуємо розмір тексту -->
            <item name="android:textColor">@android:color/white</item> <!-- Білий текст -->
        </style>

    <style name="CircularImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShopTextCardStyle" parent="Widget.AppCompat.TextView">
        <item name="android:textColor">@color/textColorPrimary</item> <!-- Використовуємо адаптивний ресурс -->
    </style>

    <style name="MyRoundedImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
    </resources>
