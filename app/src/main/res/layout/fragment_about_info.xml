                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textv1"
                android:textSize="38sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/textv3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ecom is a conceptual clothing brand that combines minimalistic design with everyday comfort. This project demonstrates how a modern online fashion store can look and work, from product gallery and cart to a dark / light theme and fully responsive layout."
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textv2"
                android:textSize="18sp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/textv4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="The main focus is clear visual structure, consistent UX and the use of modern frontend techniques without heavy frameworks."
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textv3"
                android:textSize="18sp"
                android:layout_marginTop="10dp"/>

            <ImageView
                android:id="@+id/imagv1"
                android:layout_width="0dp"
                android:layout_height="330dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textv4"
