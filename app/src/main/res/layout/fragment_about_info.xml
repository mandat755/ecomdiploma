                android:scaleType="fitXY"/>

            <TextView
                android:id="@+id/textv5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Our Mission"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/imagv1"
                android:textSize="30sp"
                android:layout_marginTop="40dp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/textv6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="To create a clean, intuitive shopping experience that highlights the product first. Every decision in the interface — from typography to colors — is made to support clarity and ease of use."
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textv5"
                android:textSize="18sp"
                android:layout_marginTop="10dp"
                android:gravity="center"/>

            <TextView
                android:id="@+id/textv7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Our Vision"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textv6"
                android:textSize="30sp"
                android:layout_marginTop="40dp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/textv8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A digital storefront that could be easily extended into a real production environment: dynamic product pages, reusable layouts and scalable architecture for future development."
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textv7"
                android:textSize="18sp"
                android:layout_marginTop="10dp"
                android:gravity="center"/>

            <TextView
                android:id="@+id/textv9"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Technology"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textv8"
                android:textSize="30sp"
                android:layout_marginTop="40dp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/textv10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="The project uses HTML, CSS, Bootstrap, vanilla JavaScript and localStorage for the cart system. Dark mode and dynamic product loading are implemented without heavy frameworks."
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textv9"
                android:textSize="18sp"
                android:layout_marginTop="10dp"
                android:gravity="center"/>

            <TextView
                android:id="@+id/textv11"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20+"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textv10"
                android:textSize="30sp"
                android:layout_marginTop="60dp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/textv12"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Demo products in the catalog"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textv11"
                android:textSize="18sp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/textv13"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textv12"
                android:textSize="30sp"
                android:layout_marginTop="10dp"
                android:textStyle="bold"/>

