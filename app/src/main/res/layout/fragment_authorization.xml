<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".presentation.fragments.authfrag.AuthorizationFragment"
    android:background="@color/auth_background_color">


    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gd1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.55"/>

    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:src="@drawable/black_logo_auth"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/gd1"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/googleSignInButton"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sign in with Google"
        android:textColor="@android:color/white"
        app:icon="@drawable/google_icon"
    app:iconGravity="textStart"
    app:iconPadding="8dp"
    app:layout_constraintBottom_toBottomOf="@id/gd1"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:cornerRadius="8dp"
    app:backgroundTint="@color/orange" />

    <ImageView
        android:id="@+id/imageViewGirl"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/hero4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/googleSignInButton"
        android:scaleType="fitXY"
        android:layout_marginTop="18dp"
        android:layout_marginStart="-140dp"
        android:layout_marginEnd="-20dp"
        android:layout_marginBottom="-2dp"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gd2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.53"/>

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/cindarella_logo"
        android:id="@+id/brand1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="@id/gd2"
        app:layout_constraintTop_toTopOf="@id/gd1" />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/brand2"
        android:src="@drawable/right_checl_logo"
        app:layout_constraintTop_toBottomOf="@id/brand1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="@id/gd2"
        android:layout_marginTop="-25dp"/>

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/brand3"
        android:src="@drawable/skill_star_logo"
        app:layout_constraintTop_toBottomOf="@id/brand2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="@id/gd2"
        android:layout_marginTop="-25dp"/>
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/brand4"
        android:src="@drawable/sls_logo"
        app:layout_constraintTop_toBottomOf="@id/brand3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="@id/gd2"
        android:layout_marginTop="-25dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
