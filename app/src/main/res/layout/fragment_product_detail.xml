<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".presentation.fragments.prodfrag.ProductDetailFragment">

    <!-- Весь вміст обертаємо в NestedScrollView -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/prodScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ConstraintLayout всередині NestedScrollView -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Image for the product -->
            <ImageView
                android:id="@+id/productImage"
                android:layout_width="wrap_content"
                android:layout_height="320dp"
                android:src="@drawable/tee1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:scaleType="fitXY"/>

            <View
                android:id="@+id/lineTwo"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="@color/orange"
                app:layout_constraintBottom_toTopOf="@id/imageGalleryScroll"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="5dp"/>

            <LinearLayout
                android:id="@+id/imageGalleryScroll"
                app:layout_constraintTop_toBottomOf="@id/productImage"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:orientation="horizontal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <!-- Add product image thumbnails here -->
                <ImageView
                    android:id="@+id/imchain1"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/tee1" />
                <ImageView
                    android:id="@+id/imchain2"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/tee2" />
                <ImageView
                    android:id="@+id/imchain3"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/tee3"/>
                <ImageView
                    android:id="@+id/imchain4"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/tee4"/>
            </LinearLayout>

            <View
                android:id="@+id/lineThree"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="@color/orange"
                app:layout_constraintTop_toBottomOf="@id/imageGalleryScroll"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="5dp"/>

            <!-- Product Name -->
            <TextView
                android:id="@+id/productName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Midnight Urban Pack"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/imageGalleryScroll"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="8dp"/>

            <!-- Product Price -->
            <TextView
                android:id="@+id/productPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$75.00"
                android:textSize="30sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/productName"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="8dp"
                android:layout_marginTop="12dp"/>

            <!-- Size selector -->
            <Spinner
                android:id="@+id/sizeSelector"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:entries="@array/sizes_array"
                app:layout_constraintTop_toBottomOf="@id/productPrice"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="18dp"
                android:layout_marginStart="8dp"
                style="@style/CustomSpinnerStyle"/>

            <!-- Add to Cart button -->
            <Button
                android:id="@+id/addToCartButton"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="2dp"
                android:text="Buy Now"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:padding="12dp"
                app:layout_constraintTop_toBottomOf="@id/sizeSelector"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Product description -->
            <TextView
                android:id="@+id/textproddet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/addToCartButton"
                app:layout_constraintStart_toStartOf="parent"
                android:textStyle="bold"
                android:text="Product Details"
                android:textSize="20sp"
                android:layout_marginTop="8dp"
                android:layout_marginStart="8dp"/>

            <TextView
                android:id="@+id/productDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Midnight Urban Pack is a sleek, modern backpack designed for everyday city life. With its clean lines, deep midnight tone, and practical layout, it offers the perfect balance of style and functionality."
                android:textSize="17sp"
                app:layout_constraintTop_toBottomOf="@id/textproddet"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/textFeat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/productDescription"
                android:text="Our Featured"
                android:textStyle="bold"
                android:textSize="20sp"
                android:layout_marginTop="6dp"/>

            <View
                android:id="@+id/lineOne"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="@color/orange"
                app:layout_constraintTop_toBottomOf="@id/textFeat"
                app:layout_constraintStart_toStartOf="@id/textFeat"
                app:layout_constraintEnd_toEndOf="@id/textFeat"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_marginTop="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/lineOne"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginStart="2dp"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>